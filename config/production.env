# Trading Bot Production Configuration
# This file contains all non-sensitive configuration values
# Secrets are stored separately in .env.secrets (created during deployment)

# ============================================
# Docker Registry
# ============================================
DOCKER_REGISTRY=docker.io
DOCKER_NAMESPACE=iamzion

# ============================================
# Environment
# ============================================
ENVIRONMENT=production

# ============================================
# Server Configuration
# ============================================
HTTP_PORT=8080
HTTP_READ_TIMEOUT=30
HTTP_WRITE_TIMEOUT=120
HTTP_IDLE_TIMEOUT=60
HTTP_SHUTDOWN_TIMEOUT=10

# ============================================
# Cron Configuration
# ============================================
# Cron scheduler timezone (Vietnam: Asia/Ho_Chi_Minh)
CRON_TIMEZONE=Asia/Ho_Chi_Minh

# ============================================
# MongoDB Configuration
# ============================================
MONGODB_DATABASE=bot_trade

# ============================================
# Multi-Provider Configuration
# ============================================
DEFAULT_PROVIDER_RPS=50
PRIMARY_PROVIDER=vps
MAX_PROVIDER_RPS=100

# ============================================
# Bullish RSI Job Configuration
# ============================================
BULLISH_TIMEOUT_MINUTES=30
BULLISH_CONCURRENCY=5
BULLISH_1H_ENABLED=false
BULLISH_1H_SCHEDULE=0 0 9-15 * * 1-5
BULLISH_1D_ENABLED=false
BULLISH_1D_SCHEDULE=0 0 12 * * 1-5
BULLISH_1W_ENABLED=false
BULLISH_1W_SCHEDULE=0 0 15 * * 1-5

# ============================================
# Bearish RSI Job Configuration
# ============================================
BEARISH_TIMEOUT_MINUTES=30
BEARISH_CONCURRENCY=5
BEARISH_1H_ENABLED=false
BEARISH_1H_SCHEDULE=0 0 9-15 * * 1-5
BEARISH_1D_ENABLED=false
BEARISH_1D_SCHEDULE=0 0 12 * * 1-5
BEARISH_1W_ENABLED=false
BEARISH_1W_SCHEDULE=0 0 15 * * 1-5

# ============================================
# Breakout Trendline Job Configuration
# ============================================
BREAKOUT_TIMEOUT_MINUTES=30
BREAKOUT_CONCURRENCY=5
BREAKOUT_1H_ENABLED=false
BREAKOUT_1H_SCHEDULE=0 0 9-15 * * 1-5
BREAKOUT_1D_ENABLED=false
BREAKOUT_1D_SCHEDULE=0 0 12 * * 1-5
BREAKOUT_1W_ENABLED=false
BREAKOUT_1W_SCHEDULE=0 0 15 * * 1-5

# ============================================
# Breakdown Trendline Job Configuration
# ============================================
BREAKDOWN_TIMEOUT_MINUTES=30
BREAKDOWN_CONCURRENCY=5
BREAKDOWN_1H_ENABLED=false
BREAKDOWN_1H_SCHEDULE=0 0 9-15 * * 1-5
BREAKDOWN_1D_ENABLED=false
BREAKDOWN_1D_SCHEDULE=0 0 12 * * 1-5
BREAKDOWN_1W_ENABLED=false
BREAKDOWN_1W_SCHEDULE=0 0 15 * * 1-5

# ============================================
# Stock Refresh Job Configuration
# ============================================
STOCK_REFRESH_ENABLED=false
STOCK_REFRESH_SCHEDULE=0 0 15 * * 1-5
STOCK_REFRESH_TIMEOUT_MINUTES=60
STOCK_REFRESH_CONCURRENCY=20

# ============================================
# Stock Alert Job Configuration
# ============================================
# Runs every 15 seconds during Vietnam trading hours (9:00-14:59) on weekdays.
STOCK_ALERT_ENABLED=true
STOCK_ALERT_SCHEDULE=*/15 * * * * *
STOCK_ALERT_TIMEOUT_MINUTES=2

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=info

# ============================================
# Signal Threshold Configuration
# ============================================
SIGNAL_DAYS_THRESHOLD=50

GOMEMLIMIT=230