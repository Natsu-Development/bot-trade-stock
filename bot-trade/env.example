# Trading Bot Configuration
# Copy this file to .env and update the values as needed

# ============================================
# Server Configuration
# ============================================
HTTP_PORT=8080
HTTP_READ_TIMEOUT=15
HTTP_WRITE_TIMEOUT=15
HTTP_IDLE_TIMEOUT=60
HTTP_SHUTDOWN_TIMEOUT=10

# ============================================
# MongoDB Configuration
# ============================================
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=bot_trade

# ============================================
# VietCap API Configuration
# ============================================
# Rate limit for VietCap API requests (per minute)
VIETCAP_RATE_LIMIT=100

# ============================================
# Bullish RSI Job Configuration
# ============================================
BULLISH_AUTO_START=true
BULLISH_TIMEOUT_MINUTES=30
BULLISH_CONCURRENCY=5
BULLISH_1H_ENABLED=true
BULLISH_1H_SCHEDULE=0 9 * * 1-5
BULLISH_1D_ENABLED=true
BULLISH_1D_SCHEDULE=0 10 * * 1-5
BULLISH_1W_ENABLED=false
BULLISH_1W_SCHEDULE=

# ============================================
# Bearish RSI Job Configuration
# ============================================
BEARISH_AUTO_START=true
BEARISH_TIMEOUT_MINUTES=30
BEARISH_CONCURRENCY=5
BEARISH_1H_ENABLED=true
BEARISH_1H_SCHEDULE=0 11 * * 1-5
BEARISH_1D_ENABLED=true
BEARISH_1D_SCHEDULE=0 12 * * 1-5
BEARISH_1W_ENABLED=false
BEARISH_1W_SCHEDULE=

# ============================================
# Breakout Trendline Job Configuration
# ============================================
BREAKOUT_AUTO_START=true
BREAKOUT_TIMEOUT_MINUTES=30
BREAKOUT_CONCURRENCY=5
BREAKOUT_1H_ENABLED=true
BREAKOUT_1H_SCHEDULE=0 13 * * 1-5
BREAKOUT_1D_ENABLED=true
BREAKOUT_1D_SCHEDULE=0 14 * * 1-5
BREAKOUT_1W_ENABLED=false
BREAKOUT_1W_SCHEDULE=

# ============================================
# Breakdown Trendline Job Configuration
# ============================================
BREAKDOWN_AUTO_START=true
BREAKDOWN_TIMEOUT_MINUTES=30
BREAKDOWN_CONCURRENCY=5
BREAKDOWN_1H_ENABLED=true
BREAKDOWN_1H_SCHEDULE=0 15 * * 1-5
BREAKDOWN_1D_ENABLED=true
BREAKDOWN_1D_SCHEDULE=0 16 * * 1-5
BREAKDOWN_1W_ENABLED=false
BREAKDOWN_1W_SCHEDULE=

# ============================================
# Stock Refresh Job Configuration
# ============================================
STOCK_REFRESH_ENABLED=true
STOCK_REFRESH_SCHEDULE=0 8 * * 1
STOCK_REFRESH_TIMEOUT_MINUTES=60

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=info
ENVIRONMENT=development
