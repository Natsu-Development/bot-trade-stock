# Trading Bot Configuration
# Copy this file to .env and update the values as needed

# ============================================
# Server Configuration
# ============================================
HTTP_PORT=8080
HTTP_READ_TIMEOUT=15
HTTP_WRITE_TIMEOUT=120
HTTP_IDLE_TIMEOUT=60
HTTP_SHUTDOWN_TIMEOUT=10

# ============================================
# Cron Configuration
# ============================================
# Cron scheduler timezone (Vietnam: Asia/Ho_Chi_Minh)
CRON_TIMEZONE=Asia/Ho_Chi_Minh

# ============================================
# MongoDB Configuration
# ============================================
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=bot_trade

# ============================================
# Multi-Provider Configuration
# ============================================
# Initial requests per second for adaptive token bucket
DEFAULT_PROVIDER_RPS=15
# Hard ceiling for adaptive token bucket (true provider cap is unknown — start conservative)
MAX_PROVIDER_RPS=100
# Primary provider name (e.g., "vps", "vietcap", "ssi")
PRIMARY_PROVIDER=vietcap

# ============================================
# Bullish RSI Job Configuration
# ============================================
BULLISH_TIMEOUT_MINUTES=30
BULLISH_CONCURRENCY=5
# Hourly during session
BULLISH_1H_ENABLED=true
BULLISH_1H_SCHEDULE=0 1 9-15 * * 1-5
# Twice daily: lunch 12:10 + after close 15:10 (≤15:20)
BULLISH_1D_ENABLED=true
BULLISH_1D_SCHEDULE=0 10 12,15 * * 1-5
# Friday after close 15:08
BULLISH_1W_ENABLED=true
BULLISH_1W_SCHEDULE=0 8 15 * * 5

# ============================================
# Bearish RSI Job Configuration
# ============================================
BEARISH_TIMEOUT_MINUTES=30
BEARISH_CONCURRENCY=5
# Hourly during session
BEARISH_1H_ENABLED=true
BEARISH_1H_SCHEDULE=0 3 9-15 * * 1-5
# Twice daily: lunch 12:13 + after close 15:13 (≤15:20)
BEARISH_1D_ENABLED=true
BEARISH_1D_SCHEDULE=0 13 12,15 * * 1-5
# Friday after close 15:09
BEARISH_1W_ENABLED=true
BEARISH_1W_SCHEDULE=0 9 15 * * 5

# ============================================
# Breakout Trendline Job Configuration (1D omitted — covered by tick path)
# ============================================
BREAKOUT_TIMEOUT_MINUTES=30
BREAKOUT_CONCURRENCY=5
# Hourly during session
BREAKOUT_1H_ENABLED=true
BREAKOUT_1H_SCHEDULE=0 5 9-15 * * 1-5
# Twice daily: lunch 12:16 + after close 15:16 (≤15:20)
BREAKOUT_1W_ENABLED=true
BREAKOUT_1W_SCHEDULE=0 16 12,15 * * 1-5

# ============================================
# Breakdown Trendline Job Configuration (1D omitted — covered by tick path)
# ============================================
BREAKDOWN_TIMEOUT_MINUTES=30
BREAKDOWN_CONCURRENCY=5
# Hourly during session
BREAKDOWN_1H_ENABLED=true
BREAKDOWN_1H_SCHEDULE=0 7 9-15 * * 1-5
# Twice daily: lunch 12:19 + after close 15:19 (≤15:20)
BREAKDOWN_1W_ENABLED=true
BREAKDOWN_1W_SCHEDULE=0 19 12,15 * * 1-5

# ============================================
# Stock Refresh Job Configuration
# ============================================
STOCK_REFRESH_ENABLED=true
STOCK_REFRESH_SCHEDULE=0 0 9 * * 1-5
STOCK_REFRESH_TIMEOUT_MINUTES=60
STOCK_REFRESH_CONCURRENCY=20

# ============================================
# Stock Alert Job Configuration
# ============================================
# Runs every 15 seconds during Vietnam trading hours (9:00-14:59) on weekdays.
STOCK_ALERT_ENABLED=true
STOCK_ALERT_SCHEDULE=*/15 * 9-14 * * 1-5
STOCK_ALERT_TIMEOUT_MINUTES=2
# When true, the stock-alert job runs every cron tick regardless of HoSE
# session state. Intended for local development/demo only. Production MUST
# leave this false so ATO (09:00-09:15) and lunch (11:30-13:00) ticks are skipped.
STOCK_ALERT_IGNORE_SESSION_GATE=false

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=info
ENVIRONMENT=development

# ============================================
# SSI Credentials Configuration
# ============================================
# Path to the env file written by scripts/ssi-bypass/refresh-cookies.sh.
# Required only when ENVIRONMENT=production; local development does not load
# the cookie-refresh credential store.
# SSI_CREDENTIALS_ENV_PATH=/etc/bot-trade/ssi.env
