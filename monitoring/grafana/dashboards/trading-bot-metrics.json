      "targets": [
        {
          "expr": "sum by (provider) (rate(provider_request_duration_seconds_sum{job=~\"$job\",instance=~\"$instance\",provider=~\"$provider\"}[$__rate_interval])) / clamp_min(sum by (provider) (rate(provider_request_duration_seconds_count{job=~\"$job\",instance=~\"$instance\",provider=~\"$provider\"}[$__rate_interval])), 1e-9)",
          "legendFormat": "{{provider}}",
          "refId": "A"
