          "expr": "sum by (provider, error_type) (rate(provider_errors_total{job=~\"$job\",instance=~\"$instance\",provider=~\"$provider\"}[$__rate_interval]))",
          "legendFormat": "{{provider}} • {{error_type}}",
          "refId": "A"
        }
      ]
    },
