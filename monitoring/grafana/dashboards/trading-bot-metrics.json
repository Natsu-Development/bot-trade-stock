  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "trading-bot",
    "metrics",
    "prometheus",
    "grafana"
  ],
  "templating": {
    "list": [
      {
        "name": "job",
        "label": "Job",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(up, job)",
        "definition": "label_values(up, job)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 1,
        "hide": 0,
        "current": {
          "selected": true,
          "text": "bot-trade",
          "value": "bot-trade"
        },
        "options": []
      },
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(up{job=~\"$job\"}, instance)",
        "definition": "label_values(up{job=~\"$job\"}, instance)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "sort": 1,
        "hide": 0,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "options": []
      },
      {
        "name": "provider",
        "label": "Provider",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(provider_requests_total{job=~\"$job\",instance=~\"$instance\"}, provider)",
        "definition": "label_values(provider_requests_total{job=~\"$job\",instance=~\"$instance\"}, provider)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "sort": 1,
        "hide": 0,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "options": []
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
